# ------------------------------------------------
# GIT
# ------------------------------------------------
.git/
.gitignore

# ------------------------------------------------
# Python
# ------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

venv/
.env

# ------------------------------------------------
# DATA (NEVER SHIP)
# ------------------------------------------------
data/
datasets/
notebooks/

# ------------------------------------------------
# MODEL ARTIFACTS
# Mount these at runtime instead
# ------------------------------------------------
artifacts/
!artifacts/.gitkeep
artifacts/training_runs/

# ------------------------------------------------
# HF / Torch / Pip caches
# ------------------------------------------------
.huggingface/
.cache/
.cache/huggingface/
.cache/torch/
.cache/pip/

# ------------------------------------------------
# Tests / Dev
# ------------------------------------------------
tests/
coverage/
htmlcov/
.pytest_cache/

# ------------------------------------------------
# Build junk
# ------------------------------------------------
*.log
*.tmp
*.swp
*.pid

# ------------------------------------------------
# Node junk
# ------------------------------------------------
node_modules/

# ------------------------------------------------
# OS
# ------------------------------------------------
.DS_Store
Thumbs.db
