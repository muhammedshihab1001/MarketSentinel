########################################################
# APPLICATION
########################################################

APP_ENV=development
LOG_LEVEL=INFO

# prevents running prod config accidentally
ENV_GUARD=development


########################################################
# HARDWARE / RUNTIME
########################################################

FINBERT_DEVICE=auto
TOKENIZERS_PARALLELISM=false

OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1

PYTHONHASHSEED=42


########################################################
# MODEL LOADING
########################################################

MODEL_WARMUP=true
MODEL_STRICT_LOAD=true


########################################################
# MODEL REGISTRIES
########################################################

XGB_REGISTRY_DIR=artifacts/xgboost
SARIMAX_REGISTRY_DIR=artifacts/sarimax
LSTM_REGISTRY_DIR=artifacts/lstm

MODEL_REGISTRY_PATH=artifacts/registry


########################################################
# FEATURE STORE
########################################################

FEATURE_STORE_PATH=artifacts/feature_store


########################################################
# NEWS PROVIDERS (REQUIRED FOR SENTIMENT)
########################################################

MARKETAUX_API_KEY=YOUR_KEY_HERE
GNEWS_API_KEY=YOUR_KEY_HERE

NEWS_PROVIDER_FAILOVER=true
NEWS_TIMEOUT_SECONDS=6
NEWS_MAX_RETRIES=2

# CRITICAL:
# If false → training will NOT crash if news fails
NEWS_NON_BLOCKING=true


########################################################
# MARKET DATA
########################################################

MARKET_PROVIDER=finnhub   # finnhub | yahoo
MARKET_DATA_TIMEOUT=10


########################################################
# REDIS (INFERENCE CACHE)
########################################################

REDIS_HOST=localhost
REDIS_PORT=6379

INFERENCE_CACHE_TTL_SECONDS=900
CACHE_TTL_SECONDS=180


########################################################
# PIPELINE SAFETY
########################################################

PIPELINE_TIMEOUT_SECONDS=12
HARD_LATENCY_LIMIT_SECONDS=5.0

FAIL_ON_DRIFT=false
MAX_FEATURE_NULL_RATIO=0.02
MAX_DATA_AGE_HOURS=24


########################################################
# TRAINING SAFETY
########################################################

ALLOW_BASELINE_OVERWRITE=false
MIN_TRAINING_ROWS=2000
MIN_SURVIVING_RATIO=0.35


########################################################
# SIGNAL ENGINE
########################################################

PROB_THRESHOLD=0.60
MIN_CONFIDENCE=0.40
SENTIMENT_THRESHOLD=0.08

VOL_CAP=0.07
CRISIS_VOL=0.12
VOL_THROTTLE=0.045

MIN_RAR=0.35

PORTFOLIO_VALUE=100000
MAX_POSITION_PCT=0.06
MIN_POSITION_PCT=0.01
MAX_TOTAL_EXPOSURE_PCT=0.35

FLIP_COOLDOWN_SECONDS=300

GLOBAL_TRADING_DISABLED=false


########################################################
# CIRCUIT BREAKER
########################################################

INFERENCE_FAILURE_THRESHOLD=3
INFERENCE_COOLDOWN_SECONDS=120


########################################################
# DRIFT MONITORING
########################################################

DRIFT_ALERT_THRESHOLD=0.15


########################################################
# RESEARCH MODE (SAFE TOGGLES)
########################################################

RESEARCH_MODE=false
ENABLE_EXPERIMENTAL_MODELS=false
