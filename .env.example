########################################################
# MarketSentinel — Environment Configuration Template
# Copy this file to .env and fill in required values.
# Run: python scripts/generate_owner_hash.py
#      to generate OWNER_PASSWORD_HASH and JWT_SECRET.
# NEVER commit .env to git.
########################################################

########################################################
# APPLICATION
########################################################

APP_ENV=production
APP_VERSION=5.0.0
LOG_LEVEL=INFO

ENV_GUARD=production
STARTUP_TIMEOUT_SEC=120

########################################################
# API SERVER
########################################################

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_REQUEST_TIMEOUT=180
API_RATE_LIMIT_PER_MIN=180

########################################################
# AUTH — REQUIRED
# Generate with: docker-compose run --rm api python scripts/generate_owner_hash.py
########################################################

OWNER_USERNAME=your_username
OWNER_PASSWORD_HASH=
JWT_SECRET=
JWT_OWNER_EXPIRE_DAYS=30
JWT_DEMO_EXPIRE_HOURS=24

########################################################
# API KEY
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
########################################################

API_KEY=

########################################################
# DEMO LIMITS
########################################################

DEMO_REQUESTS_PER_FEATURE=10
DEMO_BLOCK_DAYS=7

########################################################
# CORS
########################################################

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

########################################################
# COOKIE SECURITY
# Set to 1 in production (requires HTTPS)
########################################################

COOKIE_SECURE=0

########################################################
# HARDWARE / THREAD CONTROL
########################################################

PYTHONHASHSEED=42
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
FINBERT_DEVICE=auto

########################################################
# MODEL LOADING
########################################################

MODEL_WARMUP=true
MODEL_STRICT_LOAD=true
MODEL_STRICT_GOVERNANCE=0
MODEL_ALLOW_POINTER_FALLBACK=1

XGB_REGISTRY_DIR=artifacts/xgboost
SARIMAX_REGISTRY_DIR=artifacts/sarimax
LSTM_REGISTRY_DIR=artifacts/lstm
MODEL_REGISTRY_PATH=artifacts/registry

########################################################
# FEATURE STORE
########################################################

FEATURE_STORE_PATH=data/features
DATA_LAKE_PATH=data/lake

########################################################
# INFERENCE ENGINE
########################################################

MAX_CONCURRENT_INFERENCES=4
INFERENCE_TIMEOUT_SEC=180

# Cold snapshot takes ~90s. Keep >= 300 to prevent concurrent runs.
SNAPSHOT_PRECOMPUTE_INTERVAL=300

SNAPSHOT_CACHE_TTL=120
INFERENCE_LOOKBACK_DAYS=400
INFERENCE_CACHE_TTL_SECONDS=900

MIN_UNIVERSE_WIDTH=8
PIPELINE_TOP_K=5
PIPELINE_BOTTOM_K=5
PIPELINE_TIMEOUT_SECONDS=12
HARD_LATENCY_LIMIT_SECONDS=5.0

########################################################
# MARKET DATA
########################################################

MARKET_PROVIDER=yahoo
MARKET_PROVIDER_PRIMARY=yahoo
MARKET_PROVIDER_FAILOVER=false
MARKET_DATA_TIMEOUT=10
MARKET_MAX_WORKERS=8
YAHOO_MAX_CONCURRENT=1

########################################################
# POSTGRESQL DATABASE
# Must match docker-compose.yml postgres service.
########################################################

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=marketsentinel

DATABASE_URL=postgresql+psycopg2://sentinel:sentinel@postgres:5432/marketsentinel

# pool_size + max_overflow must be > MARKET_MAX_WORKERS + 2 buffer
# Default 10+5=15 handles 8 workers safely
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=15
DB_POOL_RECYCLE=1800
SQL_ECHO=0

########################################################
# DATA SYNC
########################################################

SKIP_DATA_SYNC=0
DATA_SYNC_HISTORY_DAYS=730
DATA_STALENESS_HOURS=24

########################################################
# PREDICTION STORAGE
########################################################

STORE_PREDICTIONS=1

########################################################
# REDIS CACHE
# IMPORTANT: Use Docker service name "redis", NOT "localhost"
########################################################

REDIS_HOST=redis
REDIS_PORT=6379
CACHE_TTL_SECONDS=180
DRIFT_CACHE_TTL=300

########################################################
# TRAINING
########################################################

ALLOW_BASELINE_OVERWRITE=false
MIN_TRAINING_ROWS=2000
MIN_SURVIVING_RATIO=0.35

########################################################
# SIGNAL ENGINE
########################################################

PROB_THRESHOLD=0.60
MIN_CONFIDENCE=0.40
SENTIMENT_THRESHOLD=0.08

VOL_CAP=0.07
CRISIS_VOL=0.12
VOL_THROTTLE=0.045
MIN_RAR=0.35

PORTFOLIO_VALUE=100000
MAX_POSITION_PCT=0.05
MIN_POSITION_PCT=0.01
MAX_TOTAL_EXPOSURE_PCT=0.30

FLIP_COOLDOWN_SECONDS=300
GLOBAL_TRADING_DISABLED=false

########################################################
# DRIFT DETECTION
########################################################

DRIFT_HARD_FAIL=false
DRIFT_ALERT_THRESHOLD=0.15
DRIFT_RETRAIN_THRESHOLD=8
RETRAIN_COOLDOWN_SECONDS=3600
FAIL_ON_DRIFT=false

########################################################
# CIRCUIT BREAKER
########################################################

INFERENCE_FAILURE_THRESHOLD=3
INFERENCE_COOLDOWN_SECONDS=120

########################################################
# PIPELINE SAFETY
########################################################

MAX_FEATURE_NULL_RATIO=0.02
MAX_DATA_AGE_HOURS=24

########################################################
# SENTIMENT / NEWS (disabled by default)
########################################################

ENABLE_SENTIMENT=0

########################################################
# RESEARCH MODE
########################################################

RESEARCH_MODE=false
ENABLE_EXPERIMENTAL_MODELS=false

########################################################
# OBSERVABILITY
########################################################

ENABLE_PROMETHEUS=true
METRICS_NAMESPACE=marketsentinel
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

########################################################
# LOGGING
########################################################

LOG_DIR=logs

########################################################
# GRAFANA
########################################################

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

########################################################
# LLM (optional — disabled by default)
# Enable with LLM_ENABLED=true and add OPENAI_API_KEY.
# Rebuild inference image with: --build-arg INSTALL_LLM=true
########################################################

LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=12
LLM_RATE_LIMIT_PER_MIN=30
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_SEC=180
LLM_CACHE_MAX_ITEMS=500
LLM_AUDIT_ENABLED=true

########################################################
# TWELVEDATA (optional failover market data provider)
########################################################

TWELVEDATA_API_KEY=

########################################################
# DEPLOYMENT MODE
########################################################

DEPLOYMENT_MODE=production

########################################################
# POLITICAL RISK NEWS PROVIDERS (fallback chain)
# Register free accounts and paste keys below.
# All are free tier — no credit card required.
# GDELT is free with no key. Others used as fallbacks.
########################################################

# newsapi.org/register — 100 req/day free
NEWSAPI_KEY=

# gnews.io/register — 100 req/day free
GNEWS_KEY=

# thenewsapi.com/register — 100 req/day free
THENEWSAPI_KEY=

# mediastack.com/signup/free — 500 req/month free
MEDIASTACK_KEY=

# currentsapi.services/en/register — 600 req/day free
CURRENTSAPI_KEY=