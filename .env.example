########################################################
# ================== APPLICATION ======================
########################################################

APP_ENV=development
APP_VERSION=3.1.0
LOG_LEVEL=INFO

# Prevent prod config misuse
ENV_GUARD=development

STARTUP_TIMEOUT_SEC=120


########################################################
# ================== HARDWARE / RUNTIME ===============
########################################################

FINBERT_DEVICE=auto
TOKENIZERS_PARALLELISM=false

OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1

PYTHONHASHSEED=42


########################################################
# ================== MODEL LOADING ====================
########################################################

MODEL_WARMUP=true
MODEL_STRICT_LOAD=true

XGB_REGISTRY_DIR=artifacts/xgboost
MODEL_REGISTRY_PATH=artifacts/registry


########################################################
# ================== FEATURE STORE ====================
########################################################

FEATURE_STORE_PATH=artifacts/feature_store


########################################################
# ================== API LIMITS =======================
########################################################

MAX_CONCURRENT_INFERENCES=4
INFERENCE_TIMEOUT_SEC=30
MAX_BATCH_SIZE=50


########################################################
# ================== NEWS PROVIDERS ===================
########################################################

# Institutional Default: OFF
ENABLE_SENTIMENT=0

# auto | finnhub | marketaux | gnews
NEWS_PROVIDER_PRIMARY=auto

NEWS_PROVIDER_FAILOVER=true
NEWS_TIMEOUT_SECONDS=6
NEWS_MAX_RETRIES=2

# Training will NOT crash if news fails
NEWS_NON_BLOCKING=true

# Optional — set only in real .env
# FINNHUB_API_KEY=
# MARKETAUX_API_KEY=
# GNEWS_API_KEY=


########################################################
# ================== MARKET DATA ======================
########################################################

# yahoo (safe free default)
# finnhub (faster but unstable on free tier)
MARKET_PROVIDER=yahoo
MARKET_DATA_TIMEOUT=10


########################################################
# ================== REDIS ============================
########################################################

REDIS_HOST=localhost
REDIS_PORT=6379

INFERENCE_CACHE_TTL_SECONDS=900
CACHE_TTL_SECONDS=180


########################################################
# ================== PIPELINE SAFETY ==================
########################################################

PIPELINE_TIMEOUT_SECONDS=12
HARD_LATENCY_LIMIT_SECONDS=5.0

FAIL_ON_DRIFT=false
MAX_FEATURE_NULL_RATIO=0.02
MAX_DATA_AGE_HOURS=24


########################################################
# ================== TRAINING SAFETY ==================
########################################################

ALLOW_BASELINE_OVERWRITE=false

# Ensure weak datasets never train
MIN_TRAINING_ROWS=2000
MIN_SURVIVING_RATIO=0.35


########################################################
# ================== SIGNAL ENGINE ====================
########################################################

PROB_THRESHOLD=0.60
MIN_CONFIDENCE=0.40

VOL_CAP=0.07
CRISIS_VOL=0.12
VOL_THROTTLE=0.045

MIN_RAR=0.35

PORTFOLIO_VALUE=100000

MAX_POSITION_PCT=0.05
MIN_POSITION_PCT=0.01

MAX_TOTAL_EXPOSURE_PCT=0.30

FLIP_COOLDOWN_SECONDS=300
GLOBAL_TRADING_DISABLED=false


########################################################
# ================== CIRCUIT BREAKER ==================
########################################################

INFERENCE_FAILURE_THRESHOLD=3
INFERENCE_COOLDOWN_SECONDS=120


########################################################
# ================== DRIFT MONITORING =================
########################################################

DRIFT_ALERT_THRESHOLD=0.15


########################################################
# ================== RESEARCH MODE ====================
########################################################

RESEARCH_MODE=false
ENABLE_EXPERIMENTAL_MODELS=false


########################################################
# ================== OBSERVABILITY ====================
########################################################

ENABLE_PROMETHEUS=true
METRICS_NAMESPACE=marketsentinel


########################################################
# ================== DEPLOYMENT MODE ==================
########################################################

# development | staging | production
DEPLOYMENT_MODE=development