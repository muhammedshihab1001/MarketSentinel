########################################################
# ================== DATA GOVERNANCE ==================
########################################################

data/raw/
data/processed/
data/cache/
data/features/
data/news_cache/
data/sentiment_cache/

# Prevent accidental dataset leaks
*.parquet
*.feather
*.hdf5
*.sqlite
*.db

# Allow controlled CSV usage (tests/config only)
!tests/**/*.csv
!config/**/*.csv

########################################################
# ================== MODEL BINARIES ===================
########################################################

*.pkl
*.joblib
*.h5
*.pt
*.onnx
*.keras
*.model
*.bin

########################################################
# ================== ARTIFACT GOVERNANCE ==============
########################################################

# Block heavy artifacts
artifacts/**/*.pkl
artifacts/**/*.joblib
artifacts/**/*.h5
artifacts/**/*.pt
artifacts/**/*.onnx

# Allow metadata + lineage
!artifacts/**/metadata_*.json
!artifacts/**/manifest.json
!artifacts/**/drift_baseline.json
!artifacts/latest.json
!artifacts/.keep

