########################################################

.env*
!.env.example


########################################################
# JUPYTER
########################################################

.ipynb_checkpoints/


########################################################
# DATA — NEVER COMMIT MARKET DATA
########################################################

data/raw/
data/processed/
data/cache/
data/features/
data/news_cache/
data/sentiment_cache/

# Block datasets ANYWHERE in repo
**/*.csv
**/*.parquet
**/*.feather
**/*.hdf5


########################################################
# MODEL BINARIES (GLOBAL BLOCK)
########################################################

*.pkl
*.joblib
*.h5
*.pt
*.onnx
*.keras


########################################################
# ARTIFACT GOVERNANCE
########################################################

# Block ALL heavy artifacts
artifacts/**/model*
artifacts/**/*.pkl
artifacts/**/*.joblib
artifacts/**/*.keras
artifacts/**/*.pt
artifacts/**/*.onnx

# Feature store + training runs
artifacts/feature_store/
artifacts/training_runs/

# Allow governance files ONLY
!artifacts/**/manifest.json
!artifacts/latest.json

# Keep directory structure
!artifacts/.keep
!artifacts/**/.keep


########################################################
# HUGGINGFACE / TRANSFORMERS
########################################################

.cache/
.huggingface/
artifacts/huggingface/


