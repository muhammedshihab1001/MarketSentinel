########################################################
# PYTHON
########################################################

__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

.python-version


########################################################
# SECRETS — NEVER COMMIT
########################################################

.env
.env.*
!.env.example

*.pem
*.key
*.crt
*.p12
secrets/
credentials/


