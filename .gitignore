########################################################
# ================== DATA GOVERNANCE ==================
########################################################

# Ignore all data by default
data/*

# Allow directory structure
!data/.gitkeep
!data/features/
!data/features/.gitkeep

# Prevent committing feature files
data/features/*.parquet
data/features/*.feather
data/features/*.csv

########################################################
# ================== MODEL BINARIES ===================
########################################################

*.pkl
*.joblib
*.h5
*.pt
*.onnx
*.keras
*.model
*.bin

########################################################
# ================== ARTIFACT GOVERNANCE ==============
########################################################

# Ignore artifacts by default
artifacts/*

# Allow directory structure
!artifacts/.gitkeep

# Never commit model binaries inside artifacts
artifacts/**/*.pkl
artifacts/**/*.joblib
artifacts/**/*.bin
artifacts/**/*.model

########################################################
# ================== XGBOOST CACHE ====================
########################################################

xgboost_training_cache/
*.dtrain
*.buffer

