########################################################

data/
datasets/
*.csv
*.parquet
*.feather
*.hdf5
*.db


########################################################
# MODEL BINARIES
########################################################

*.pkl
*.joblib
*.h5
*.pt
*.onnx
*.keras
*.bin


########################################################
# ARTIFACT GOVERNANCE (VERY IMPORTANT)
########################################################

# Ignore heavy artifacts
artifacts/**

# BUT allow registry metadata
!artifacts/**/
!artifacts/**/*.json
!artifacts/**/*.lock

# Explicitly block model weights again
artifacts/**/*.pkl
artifacts/**/*.joblib
artifacts/**/*.keras
artifacts/**/*.onnx
artifacts/**/*.pt

# Allow governance files only
!artifacts/**/manifest.json
!artifacts/**/metadata.json
!artifacts/**/latest.json
!artifacts/**/.promotion.lock

# Keep folder structure
!artifacts/.keep
!artifacts/**/.keep


########################################################
# FEATURE STORE / TRAINING RUNS
########################################################

artifacts/feature_store/**
artifacts/training_runs/**
artifacts/cache/**
artifacts/tmp/**


